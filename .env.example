# ── Required ──────────────────────────────────────────────
DATABASE_URL=postgresql://...
BETTER_AUTH_URL=http://localhost:3000
# Generate with: npx auth@latest secret
BETTER_AUTH_SECRET=...          # local vault-session auth secret

# ── Access control ────────────────────────────────────────
# Comma-separated emails allowed to sign in.
# Leave empty to allow anyone.
ALLOWED_EMAILS=

# ── Self-host mode ────────────────────────────────────────
# Skips the landing page and waitlist. Goes straight to the vault workspace.
IS_SELF_HOSTED=true

# ── GitHub integration (optional) ─────────────────────────
# Enables the Pull requests page.
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...

# ── Linear integration (optional, coming soon) ────────────
# Enables the Issues page.
# LINEAR_CLIENT_ID=...
# LINEAR_CLIENT_SECRET=...
