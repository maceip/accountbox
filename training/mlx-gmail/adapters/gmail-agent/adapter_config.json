{
    "adapter_path": "adapters/gmail-agent",
    "batch_size": 1,
    "clear_cache_threshold": 0,
    "config": "lora_config_gmail.yaml",
    "data": "data/sft",
    "fine_tune_type": "lora",
    "grad_accumulation_steps": 1,
    "grad_checkpoint": true,
    "iters": 60,
    "learning_rate": 1.5e-05,
    "lora_parameters": {
        "keys": [
            "self_attn.q_proj",
            "self_attn.k_proj",
            "self_attn.v_proj",
            "self_attn.o_proj",
            "mlp.gate_proj",
            "mlp.up_proj",
            "mlp.down_proj"
        ],
        "rank": 16,
        "scale": 16.0,
        "dropout": 0.0
    },
    "lr_schedule": {
        "name": "cosine_decay",
        "warmup": 30,
        "warmup_init": 1e-06,
        "arguments": [
            8e-05,
            300,
            1e-06
        ]
    },
    "mask_prompt": true,
    "max_seq_length": 512,
    "model": "WeiboAI/VibeThinker-3B",
    "num_layers": 36,
    "optimizer": "adamw",
    "optimizer_config": {
        "adam": {},
        "adamw": {},
        "muon": {},
        "sgd": {},
        "adafactor": {}
    },
    "project_name": null,
    "report_to": null,
    "resume_adapter_file": "adapters/gmail-agent/adapters.safetensors",
    "save_every": 25,
    "seed": 42,
    "steps_per_eval": 25,
    "steps_per_report": 5,
    "test": false,
    "test_batches": 500,
    "train": true,
    "val_batches": 5
}