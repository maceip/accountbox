{
  "name": "betterbox",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "bun test",
    "db:generate": "bun --env-file=.env ./node_modules/.bin/prisma generate",
    "db:generate:waitlist": "bun --env-file=.env ./node_modules/.bin/prisma generate --config prisma.waitlist.config.ts",
    "db:push": "bun --env-file=.env ./node_modules/.bin/prisma db push",
    "db:push:waitlist": "bun --env-file=.env ./node_modules/.bin/prisma db push --config prisma.waitlist.config.ts",
    "db:migrate": "bun --env-file=.env ./node_modules/.bin/prisma migrate dev",
    "db:studio": "bun --env-file=.env ./node_modules/.bin/prisma studio",
    "encrypt-tokens": "bun --env-file=.env scripts/encrypt-oauth-tokens.ts",
    "set-owner": "bun --env-file=.env scripts/set-owner.ts",
    "postinstall": "prisma generate && prisma generate --config prisma.waitlist.config.ts",
    "train:gmail": "bun run training/generate-gmail-dataset.ts && bash scripts/run-gmail-finetune.sh",
    "prove:real-gmail": "bun run scripts/prove-real-gmail-serving.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/roboto": "^5.2.10",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/suggestion": "^3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.9",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.17.0",
    "nitro": "^3.0.260603-beta",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.11.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.4",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "shadcn": "^4.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
